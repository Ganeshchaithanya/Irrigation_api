{
    "version": "2.0",
    "description": "Static hardware anomaly rule book for AquaSol irrigation system",
    "note": "All thresholds are hardware-validated. Do not change without field testing.",
    "flow": {
        "no_flow_when_irrigating": {
            "description": "Valve is open and command is IRRIGATE but flow sensor reads near zero",
            "threshold_min": 0.5,
            "check_after_seconds": 30,
            "severity": "critical",
            "action": "STOP_IRRIGATION",
            "alert_code": "FL001",
            "possible_causes": [
                "pump failure",
                "pipe blockage",
                "valve stuck closed",
                "flow sensor disconnected"
            ],
            "recommended_steps": [
                "check pump power",
                "inspect pipe for blockage",
                "verify valve is physically open",
                "test flow sensor continuity"
            ]
        },
        "unexpected_flow_when_idle": {
            "description": "Flow detected when system is IDLE \u2014 no irrigation command active",
            "threshold_min": 0.3,
            "severity": "high",
            "action": "LEAK_DETECTED",
            "alert_code": "FL002",
            "possible_causes": [
                "valve stuck open",
                "pipe joint leak",
                "illegal tapping"
            ],
            "recommended_steps": [
                "close master valve",
                "inspect all pipe joints",
                "check valve seal"
            ]
        },
        "flow_too_high": {
            "description": "Flow rate exceeds maximum safe pipe capacity \u2014 possible burst",
            "threshold_max": 5.0,
            "unit": "L/min",
            "severity": "critical",
            "action": "PIPE_BURST",
            "alert_code": "FL003",
            "possible_causes": [
                "pipe burst",
                "pressure regulator failure",
                "multiple valves open simultaneously"
            ],
            "recommended_steps": [
                "close master valve immediately",
                "inspect pipeline",
                "check pressure regulator"
            ]
        },
        "flow_too_low_during_irrigation": {
            "description": "Flow is positive but significantly below expected rate during active irrigation",
            "threshold_min": 0.5,
            "expected_min": 1.0,
            "severity": "medium",
            "action": "PARTIAL_BLOCKAGE",
            "alert_code": "FL004",
            "possible_causes": [
                "partial pipe blockage",
                "drip emitter clogging",
                "low pump pressure"
            ],
            "recommended_steps": [
                "flush drip lines",
                "check filter",
                "test pump pressure"
            ]
        },
        "flow_variation_unstable": {
            "description": "Flow rate fluctuates beyond tolerance within a short window",
            "tolerance": 0.5,
            "window_seconds": 60,
            "severity": "medium",
            "action": "UNSTABLE_FLOW",
            "alert_code": "FL005",
            "possible_causes": [
                "air in pipes",
                "unstable pump",
                "partial valve obstruction"
            ],
            "recommended_steps": [
                "bleed air from pipes",
                "check pump motor",
                "inspect valve"
            ]
        },
        "flow_sensor_out_of_range": {
            "description": "Flow sensor reading is physically impossible",
            "threshold_min": 0,
            "threshold_max": 20,
            "unit": "L/min",
            "severity": "critical",
            "action": "INVALID_SENSOR",
            "alert_code": "FL006",
            "possible_causes": [
                "sensor disconnected",
                "wiring short",
                "sensor damaged"
            ],
            "recommended_steps": [
                "check sensor wiring",
                "replace flow sensor"
            ]
        },
        "no_flow_stop_after_command": {
            "description": "Flow continues after STOP command \u2014 valve not closing",
            "threshold_min": 0.3,
            "check_after_seconds": 15,
            "severity": "high",
            "action": "VALVE_STUCK_OPEN",
            "alert_code": "FL007",
            "possible_causes": [
                "valve solenoid failure",
                "debris in valve seat",
                "controller wiring fault"
